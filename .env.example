# Shared Infrastructure Variables
# Copy this file to .env and fill in your actual values

# PostgreSQL
POSTGRES_USER=shinyq
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=shinyq

# Redis
REDIS_PASSWORD=your_secure_redis_password_here

# Shared connection strings (used by app services)
DATABASE_URL=postgresql://shinyq:your_secure_password_here@postgres:5432/shinyq
REDIS_URL=redis://default:your_secure_redis_password_here@redis:6379

# Common
NODE_ENV=production
